  "components": {
    "schemas": {
      "AddIssueDto": {
        "type": "object",
        "properties": {
          "issue": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AdminLoginDto": {
        "type": "object",
        "properties": {
          "userName": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ApproveCreditLimitIncreaseDto": {
        "type": "object",
        "properties": {
          "cardId": {
            "type": "integer",
            "format": "int32"
          },
          "isApproved": {
            "type": "boolean"
          },
          "rejectionReason": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AtmStatus": {
        "enum": [
          1,
          2,
          3
        ],
        "type": "integer",
        "format": "int32"
      },
      "ChangePinRequestDto": {
        "required": [
          "newPin",
          "oldPin"
        ],
        "type": "object",
        "properties": {
          "oldPin": {
            "maxLength": 4,
            "minLength": 4,
            "type": "string"
          },
          "newPin": {
            "maxLength": 4,
            "minLength": 4,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateAccountDto": {
        "type": "object",
        "properties": {
          "ownerName": {
            "type": "string",
            "nullable": true
          },
          "initialBalance": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "CreateCardDto": {
        "type": "object",
        "properties": {
          "accountId": {
            "type": "integer",
            "format": "int32"
          },
          "cardNumber": {
            "type": "string",
            "nullable": true
          },
          "pin": {
            "type": "string",
            "nullable": true
          },
          "exxpiryDate": {
            "type": "string",
            "format": "date-time"
          },
          "creditLimit": {
            "type": "number",
            "format": "double"
